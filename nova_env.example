# nova_env.example — Vorlage fuer ~/.nova_env (Per-Node-Overrides, Tier 2)
#
# Setup pro Node (manuell, einmalig, als novaadm):
#   cp ~/nova/nova_env.example ~/.nova_env
#   chmod 600 ~/.nova_env
#   vi ~/.nova_env       # Werte fuer DIESEN Node anpassen
#
# Wird von jedem Workload-run.sh per `source ~/.nova_env` geladen
# (idempotent — fehlt die Datei, passiert nichts). Variablen sind
# danach als os.environ.* in den Python-Workloads sichtbar.
#
# Diese Vorlage (~/nova/nova_env.example) ist in git, dient als
# Dokumentation und wird mit deployed.
# Die echte ~/.nova_env ist gitignored, lebt nur lokal pro Node,
# kann jederzeit ohne Deploy/Push geaendert werden.

# ============================================================
# Beispiele — alles auskommentieren bis tatsaechlich gebraucht
# ============================================================

# ---- IB Gateway / TWS Connection ----
# export IB_GATEWAY_HOST=127.0.0.1     # auf jedem Node lokal, oder LAN-IP
# export IB_GATEWAY_PORT=4001          # 4001 = Live Gateway, 7497 = TWS Paper
# export IB_ACCOUNT_ID=DUxxxxxxx       # Paper-Account beginnt mit DU
#
# Client-IDs (jede Anwendung muss eine eindeutige clientId nutzen, sonst
# kollidiert die IB-Session). Konvention nova-lab:
# export IB_CLIENT_ID=7                # ib_check (Diagnose)
# export IB_INGEST_CLIENT_ID=11        # nova-lab ingest (modules/ingest/sources/ib_src.py)
# export IB_PORTFOLIO_CLIENT_ID=12     # portfolio resolver (modules/portfolio/_ib_resolver.py)
# export IB_SCREENER_CLIENT_ID=15      # screener_csp (modules/screener_csp/ib_options.py)
# export IB_FUNDAMENTALS_CLIENT_ID=25  # fundamentals (modules/fundamentals/probe_ib.py)
#
# export IB_MARKET_DATA_TYPE=2         # 1=realtime, 2=frozen, 3=delayed, 4=delayed-frozen
# export IB_REQUEST_TIMEOUT=15         # seconds

# ---- LLM (Ollama auf nova-w5) ----
# Default-Endpoint und -Modell fuer modules.llm.OllamaClient.
# Alle nicht-w5 Nodes sollten auf nova-w5.local zeigen; w5 selbst kann
# localhost nehmen fuer minimale Latenz.
# export LLM_OLLAMA_HOST=http://nova-w5.local:11434
# export LLM_DEFAULT_MODEL=qwen2.5:14b-instruct-q4_K_M
# export LLM_TIMEOUT_S=120
# export LLM_RETRIES=3

# ---- API Keys / Secrets (vorerst nur als Beispiel; Keychain ist sauberer) ----
# export ALPHA_VANTAGE_API_KEY=xxx
# export OPENAI_API_KEY=sk-...
