.DS_Store
*.log
backups/
secrets/
*.pem
*.key
~$*

# Python
.venv/
__pycache__/
*.pyc
.python-version
.ipynb_checkpoints/

# DuckDB-Daten (nie im Repo — leben in ~/nova_data/)
*.duckdb
*.duckdb.wal
data/

# Per-Node Tier-2 Overrides (sollten unter ~/.nova_env liegen, nie im Repo).
# Defensive: falls jemand versehentlich .nova_env im Repo anlegt.
.nova_env

# Job-Queue-State (per-Node lokal in ~/nova_jobs/, nicht im Repo).
# Defensive falls jemand versehentlich nova_jobs/ im Repo anlegt.
nova_jobs/

# Per-Node Output-Sammlung (~/nova_output/ pro Worker, ~/nova_output_central/
# auf hub als Aggregation). Nie im Repo.
nova_output/
nova_output_central/
